# DeFiRe Catalyst MCP Server — Environment Variables
# Copy this file to .env and fill in the values.

# ---------- Network ----------
# Base Sepolia RPC endpoint
RPC_URL=https://sepolia.base.org

# Chain ID (84532 = Base Sepolia)
CHAIN_ID=84532

# ---------- Contract Addresses ----------
# CatalystRegistry — ERC-8183 job registry for startups & trading agents
REGISTRY_ADDRESS=

# CatalystHook — Uniswap v4 hook (investor positions, fees, token allocations)
HOOK_ADDRESS=

# ---------- Wallet (optional) ----------
# Connected wallet address — used by investor/startup/trading-agent tools
# to scope reads (e.g. get_my_positions).  Leave blank for mock data.
WALLET_ADDRESS=
