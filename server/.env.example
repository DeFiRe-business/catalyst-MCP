# DeFiRe Catalyst MCP Server — Environment Variables
# Copy this file to .env and fill in the values.

# ---------- Network ----------
# Base Sepolia RPC endpoint (or any EVM JSON-RPC URL)
RPC_URL=https://sepolia.base.org

# ---------- Contract addresses ----------
CATALYST_REGISTRY_ADDRESS=
CATALYST_HOOK_ADDRESS=
CATALYST_EVALUATOR_ADDRESS=
CATALYST_VAULT_ADDRESS=
CATALYST_EVAL_REGISTRY_ADDRESS=
CATALYST_ADOPTION_SCORER_ADDRESS=

# ---------- Optional: backend API for fast aggregated reads ----------
# When set, get_protocol_stats and get_leaderboard delegate to this backend.
BACKEND_URL=http://localhost:4700

# ---------- Optional: scan ceiling for read tools ----------
# Highest startup id the read tools will iterate to before stopping.
# MAX_STARTUPS=100

# ---------- Per-actor signing keys ----------
# Set only the ones you need. The MCP can run read-only with none configured.
FOUNDER_PRIVATE_KEY=
INVESTOR_PRIVATE_KEY=
ORACLE_PRIVATE_KEY=
ADMIN_PRIVATE_KEY=

# Fallback key used by any role when the role-specific key above is unset.
MCP_PRIVATE_KEY=
